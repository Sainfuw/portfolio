---
import '../styles/schematics.css'

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang='es' class='bg-(--bg)'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{title}</title>
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Manrope:wght@300;400;500;600;700;800&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,800&display=swap'
      rel='stylesheet'
    />
  </head>

  <body
    class='min-h-screen font-[Manrope,sans-serif] bg-(--bg) text-(--text) leading-normal p-8 max-sm:px-4 antialiased'
  >
    <div class='max-w-220 mx-auto'>
      <slot />
    </div>
  </body>
</html>
