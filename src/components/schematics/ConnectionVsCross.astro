<section class='mb-8'>
  <div class='bg-(--panel) border border-(--border) rounded-xl p-6'>
    <div
      class='text-center font-[JetBrains_Mono,monospace] font-bold text-[1.05rem] mb-5'
    >
      Conexión vs. cruce — la diferencia más importante
    </div>
    <div class='grid grid-cols-2 gap-6'>
      <!-- Conectados -->
      <div class='text-center'>
        <svg
          viewBox='0 0 100 80'
          stroke='white'
          stroke-width='2'
          fill='none'
          stroke-linecap='round'
          class='w-25 h-20 mx-auto'
        >
          <line x1='50' y1='10' x2='50' y2='70'></line>
          <line x1='10' y1='40' x2='90' y2='40'></line>
          <circle cx='50' cy='40' r='4' fill='white'></circle>
        </svg>
        <div
          class='mt-2 text-[0.85rem] text-(--text-dim) font-[JetBrains_Mono,monospace]'
        >
          Punto = SÍ conectados
        </div>
      </div>

      <!-- No conectados -->
      <div class='text-center'>
        <svg
          viewBox='0 0 100 80'
          stroke='white'
          stroke-width='2'
          fill='none'
          stroke-linecap='round'
          class='w-25 h-20 mx-auto'
        >
          <line x1='50' y1='10' x2='50' y2='70'></line>
          <line x1='10' y1='40' x2='42' y2='40'></line>
          <path d='M 42 40 Q 50 30 58 40'></path>
          <line x1='58' y1='40' x2='90' y2='40'></line>
        </svg>
        <div
          class='mt-2 text-[0.85rem] text-(--text-dim) font-[JetBrains_Mono,monospace]'
        >
          Puente = NO conectados
        </div>
      </div>
    </div>
  </div>
</section>
