---
const leftPins = [
  { gpio: 'GPIO5', func: 'A3', funcBg: '#f4a4a4', digital: 'D3' },
  { gpio: 'GPIO6', func: 'SDA', funcBg: '#7dd3c7', digital: 'D4' },
  { gpio: 'GPIO7', func: 'SCL', funcBg: '#7dd3c7', digital: 'D5' },
  { gpio: 'GPIO8', func: 'SCK', funcBg: '#b39ddb', digital: 'D8' },
  { gpio: 'GPIO9', func: 'MISO', funcBg: '#b39ddb', digital: 'D9' },
  { gpio: 'GPIO10', func: 'MOSI', funcBg: '#b39ddb', digital: 'D10' },
  { gpio: 'GPIO20', func: 'RX', funcBg: '#9ca3af', digital: 'D7' },
  { gpio: 'GPIO21', func: 'TX', funcBg: '#9ca3af', digital: 'D6' },
]

// Labels shown next to each dot on the board illustration
const leftDotLabels = ['5', '6', '7', '8', '9', '10', '20', '21']
const rightDotLabels = ['5V', 'G', '3.3', '4', '3', '2', '1', '0']

const rightPins = [
  { col1: '5V', col1Bg: '#e5484d', col1Text: '#fff' },
  { col1: 'GND', col1Bg: '#1a1a1a', col1Text: '#fff' },
  { col1: '3V3', col1Bg: '#f76b15', col1Text: '#fff' },
  {
    col1: 'D2',
    col1Bg: '#a8b5c4',
    col1Text: '#1a1a1a',
    col2: 'A2',
    col2Bg: '#f4a4a4',
    col3: 'GPIO4',
    col3Bg: '#7cb342',
  },
  {
    col1: 'D1',
    col1Bg: '#a8b5c4',
    col1Text: '#1a1a1a',
    col2: 'A1',
    col2Bg: '#f4a4a4',
    col3: 'GPIO3',
    col3Bg: '#7cb342',
  },
  {
    col1: 'D0',
    col1Bg: '#a8b5c4',
    col1Text: '#1a1a1a',
    col2: 'A0',
    col2Bg: '#f4a4a4',
    col3: 'GPIO2',
    col3Bg: '#7cb342',
  },
  {
    col1: 'ADC1-1',
    col1Bg: '#7dd3c7',
    col1Text: '#1a1a1a',
    col2: 'GPIO1',
    col2Bg: '#7cb342',
  },
  {
    col1: 'ADC1-0',
    col1Bg: '#7dd3c7',
    col1Text: '#1a1a1a',
    col2: 'GPIO0',
    col2Bg: '#7cb342',
  },
]
---

<section class='mb-8'>
  <div class='bg-(--panel) border border-(--border) rounded-xl p-6'>
    <div
      class='text-center font-[JetBrains_Mono,monospace] font-bold text-[1.15rem] mb-6'
    >
      ESP32-C3 Super Mini — Pinout
    </div>

    <div
      class='pinout grid grid-cols-[1fr_auto_1fr] gap-x-4 gap-y-1 items-center'
      style='grid-template-rows: repeat(8, auto);'
    >
      <!-- Board background spanning all rows in center column -->
      <div
        class='board-bg bg-[#0a0d12] rounded-lg overflow-hidden min-w-25 max-w-35'
        style='grid-column: 2; grid-row: 1 / -1; align-self: stretch;'
      >
        <svg
          viewBox='0 0 100 236'
          xmlns='http://www.w3.org/2000/svg'
          class='w-full h-full'
          preserveAspectRatio='none'
        >
          <!-- PCB -->
          <rect
            x='8'
            y='8'
            width='84'
            height='220'
            rx='4'
            fill='#2c3e50'
            stroke='#1a252f'
            stroke-width='1'></rect>
          <!-- USB-C -->
          <rect
            x='32'
            y='2'
            width='36'
            height='14'
            rx='3'
            fill='#7f8c8d'
            stroke='#5a6268'
            stroke-width='0.5'></rect>
          <!-- Buttons -->
          <rect
            x='22'
            y='55'
            width='14'
            height='14'
            rx='1'
            fill='#1a1a1a'
            stroke='#444'></rect>
          <rect
            x='64'
            y='55'
            width='14'
            height='14'
            rx='1'
            fill='#1a1a1a'
            stroke='#444'></rect>
          <text
            x='29'
            y='80'
            text-anchor='middle'
            fill='#8b949e'
            font-size='5'
            font-family='monospace'>BOOT</text
          >
          <text
            x='71'
            y='80'
            text-anchor='middle'
            fill='#8b949e'
            font-size='5'
            font-family='monospace'>RST</text
          >
          <!-- Chip -->
          <rect
            x='26'
            y='108'
            width='48'
            height='44'
            rx='2'
            fill='#1a1a1a'
            stroke='#444'></rect>
          <!-- Antenna -->
          <rect
            x='32'
            y='165'
            width='36'
            height='24'
            fill='#d4a74a'
            opacity='0.3'></rect>
          <path
            d='M 35 168 L 65 168 L 65 186 L 35 186 Z'
            fill='none'
            stroke='#d4a74a'
            stroke-width='0.5'></path>
          <!-- Bottom labels -->
          <text
            x='18'
            y='228'
            fill='#8b949e'
            font-size='6'
            font-family='monospace'>21</text
          >
          <text
            x='50'
            y='228'
            text-anchor='middle'
            fill='#8b949e'
            font-size='6'
            font-family='monospace'>C3</text
          >
          <text
            x='82'
            y='228'
            fill='#8b949e'
            font-size='6'
            font-family='monospace'>0</text
          >
        </svg>
      </div>

      <!-- Rows: left pin | dot pair | right pin (all in the same grid row) -->
      {
        leftPins.map((lpin, i) => {
          const rpin = rightPins[i]
          return (
            <>
              {/* Left pin */}
              <div
                class='grid grid-cols-3 gap-0.75 items-center'
                style={`grid-column: 1; grid-row: ${i + 1};`}
              >
                <div class='pin' style='background: #7cb342'>
                  {lpin.gpio}
                </div>
                <div
                  class='pin'
                  style={`background: ${lpin.funcBg}; color: #1a1a1a`}
                >
                  {lpin.func}
                </div>
                <div class='pin' style='background: #a8b5c4; color: #1a1a1a'>
                  {lpin.digital}
                </div>
              </div>

              {/* Dot pair with labels (on top of board background) */}
              <div
                class='dot-pair flex justify-between items-center px-0.5'
                style={`grid-column: 2; grid-row: ${i + 1}; z-index: 1;`}
              >
                <div class='flex items-center gap-0.5'>
                  <div class='w-[5px] h-[5px] rounded-full bg-[#d4a74a] shrink-0' />
                  <span class='text-[10px] text-[#8b949e] font-[monospace] leading-none select-none'>
                    {leftDotLabels[i]}
                  </span>
                </div>
                <div class='flex items-center gap-0.5'>
                  <span class='text-[10px] text-[#8b949e] font-[monospace] leading-none select-none'>
                    {rightDotLabels[i]}
                  </span>
                  <div class='w-[5px] h-[5px] rounded-full bg-[#d4a74a] shrink-0' />
                </div>
              </div>

              {/* Right pin */}
              <div
                class='grid grid-cols-3 gap-0.75 items-center'
                style={`grid-column: 3; grid-row: ${i + 1};`}
              >
                <div
                  class='pin'
                  style={`background: ${rpin.col1Bg}; color: ${rpin.col1Text || '#fff'}`}
                >
                  {rpin.col1}
                </div>
                {rpin.col2 ? (
                  <div
                    class='pin'
                    style={`background: ${rpin.col2Bg}; color: #1a1a1a`}
                  >
                    {rpin.col2}
                  </div>
                ) : (
                  <div class='pin empty' />
                )}
                {rpin.col3 ? (
                  <div class='pin' style={`background: ${rpin.col3Bg}`}>
                    {rpin.col3}
                  </div>
                ) : (
                  <div class='pin empty' />
                )}
              </div>
            </>
          )
        })
      }
    </div>
  </div>
</section>
