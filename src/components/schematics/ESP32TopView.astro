---
// Rear view = front view mirrored horizontally
// Front LEFT (GPIO5-21) → Rear RIGHT
// Front RIGHT (5V,GND,3V3,GPIO4-0) → Rear LEFT

const leftPins = [
  { col1: '5V', col1Bg: '#e5484d', col1Text: '#fff' },
  { col1: 'GND', col1Bg: '#1a1a1a', col1Text: '#fff' },
  { col1: '3V3', col1Bg: '#f76b15', col1Text: '#fff' },
  {
    col1: 'GPIO4',
    col1Bg: '#7cb342',
    col1Text: '#fff',
    col2: 'A2',
    col2Bg: '#f4a4a4',
    col3: 'D2',
    col3Bg: '#a8b5c4',
  },
  {
    col1: 'GPIO3',
    col1Bg: '#7cb342',
    col1Text: '#fff',
    col2: 'A1',
    col2Bg: '#f4a4a4',
    col3: 'D1',
    col3Bg: '#a8b5c4',
  },
  {
    col1: 'GPIO2',
    col1Bg: '#7cb342',
    col1Text: '#fff',
    col2: 'A0',
    col2Bg: '#f4a4a4',
    col3: 'D0',
    col3Bg: '#a8b5c4',
  },
  {
    col1: 'GPIO1',
    col1Bg: '#7cb342',
    col1Text: '#fff',
    col2: 'ADC1-1',
    col2Bg: '#7dd3c7',
  },
  {
    col1: 'GPIO0',
    col1Bg: '#7cb342',
    col1Text: '#fff',
    col2: 'ADC1-0',
    col2Bg: '#7dd3c7',
  },
]

// Labels shown next to each dot on the board illustration (mirrored from front)
const leftDotLabels = ['5V', 'G', '3.3', '4', '3', '2', '1', '0']
const rightDotLabels = ['5', '6', '7', '8', '9', '10', '20', '21']

const rightPins = [
  { gpio: 'GPIO5', func: 'A3', funcBg: '#f4a4a4', digital: 'D3' },
  { gpio: 'GPIO6', func: 'SDA', funcBg: '#7dd3c7', digital: 'D4' },
  { gpio: 'GPIO7', func: 'SCL', funcBg: '#7dd3c7', digital: 'D5' },
  { gpio: 'GPIO8', func: 'SCK', funcBg: '#b39ddb', digital: 'D8' },
  { gpio: 'GPIO9', func: 'MISO', funcBg: '#b39ddb', digital: 'D9' },
  { gpio: 'GPIO10', func: 'MOSI', funcBg: '#b39ddb', digital: 'D10' },
  { gpio: 'GPIO20', func: 'RX', funcBg: '#9ca3af', digital: 'D7' },
  { gpio: 'GPIO21', func: 'TX', funcBg: '#9ca3af', digital: 'D6' },
]
---

<section class='mb-8'>
  <div class='bg-(--panel) border border-(--border) rounded-xl p-6'>
    <div
      class='text-center font-[JetBrains_Mono,monospace] font-bold text-[1.15rem] mb-6'
    >
      ESP32-C3 Super Mini — Vista posterior
    </div>

    <div
      class='pinout grid grid-cols-[1fr_auto_1fr] gap-x-4 gap-y-1 items-center'
      style='grid-template-rows: repeat(8, auto);'
    >
      <!-- Board background spanning all rows in center column -->
      <div
        class='board-bg bg-[#0a0d12] rounded-lg overflow-hidden min-w-25 max-w-35'
        style='grid-column: 2; grid-row: 1 / -1; align-self: stretch;'
      >
        <svg
          viewBox='0 0 100 236'
          xmlns='http://www.w3.org/2000/svg'
          class='w-full h-full'
          preserveAspectRatio='none'
        >
          <!-- PCB -->
          <rect
            x='8'
            y='8'
            width='84'
            height='220'
            rx='4'
            fill='#2c3e50'
            stroke='#1a252f'
            stroke-width='1'></rect>
          <!-- USB-C -->
          <rect
            x='32'
            y='2'
            width='36'
            height='14'
            rx='3'
            fill='#7f8c8d'
            stroke='#5a6268'
            stroke-width='0.5'></rect>
          <!-- Antenna trace (visible on back) -->
          <rect
            x='32'
            y='165'
            width='36'
            height='24'
            fill='#d4a74a'
            opacity='0.3'></rect>
          <path
            d='M 35 168 L 65 168 L 65 186 L 35 186 Z'
            fill='none'
            stroke='#d4a74a'
            stroke-width='0.5'></path>
          <!-- REAR label -->
          <text
            x='50'
            y='118'
            text-anchor='middle'
            fill='#8b949e'
            font-family='monospace'
            font-size='7'
            opacity='0.5'>REAR</text
          >
        </svg>
      </div>

      <!-- Rows: left pin | dot pair | right pin (all in the same grid row) -->
      {
        leftPins.map((lpin, i) => {
          const rpin = rightPins[i]
          return (
            <>
              {/* Left pin (front's right side, mirrored — col3 | col2 | col1) */}
              <div
                class='grid grid-cols-3 gap-0.75 items-center'
                style={`grid-column: 1; grid-row: ${i + 1};`}
              >
                {lpin.col3 ? (
                  <div
                    class='pin'
                    style={`background: ${lpin.col3Bg}; color: #1a1a1a`}
                  >
                    {lpin.col3}
                  </div>
                ) : (
                  <div class='pin empty' />
                )}
                {lpin.col2 ? (
                  <div
                    class='pin'
                    style={`background: ${lpin.col2Bg}; color: #1a1a1a`}
                  >
                    {lpin.col2}
                  </div>
                ) : (
                  <div class='pin empty' />
                )}
                <div
                  class='pin'
                  style={`background: ${lpin.col1Bg}; color: ${lpin.col1Text}`}
                >
                  {lpin.col1}
                </div>
              </div>

              {/* Dot pair with labels (on top of board background) */}
              <div
                class='dot-pair flex justify-between items-center px-0.5'
                style={`grid-column: 2; grid-row: ${i + 1}; z-index: 1;`}
              >
                <div class='flex items-center gap-0.5'>
                  <div class='w-[5px] h-[5px] rounded-full bg-[#d4a74a] shrink-0' />
                  <span class='text-[10px] text-[#8b949e] font-[monospace] leading-none select-none'>
                    {leftDotLabels[i]}
                  </span>
                </div>
                <div class='flex items-center gap-0.5'>
                  <span class='text-[10px] text-[#8b949e] font-[monospace] leading-none select-none'>
                    {rightDotLabels[i]}
                  </span>
                  <div class='w-[5px] h-[5px] rounded-full bg-[#d4a74a] shrink-0' />
                </div>
              </div>

              {/* Right pin (front's left side, mirrored — digital | func | gpio) */}
              <div
                class='grid grid-cols-3 gap-0.75 items-center'
                style={`grid-column: 3; grid-row: ${i + 1};`}
              >
                <div class='pin' style='background: #a8b5c4; color: #1a1a1a'>
                  {rpin.digital}
                </div>
                <div
                  class='pin'
                  style={`background: ${rpin.funcBg}; color: #1a1a1a`}
                >
                  {rpin.func}
                </div>
                <div class='pin' style='background: #7cb342'>
                  {rpin.gpio}
                </div>
              </div>
            </>
          )
        })
      }
    </div>
  </div>
</section>
